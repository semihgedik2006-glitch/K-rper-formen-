# ============================================================
#  Körperformen Webseite – Konfiguration
#  Kopiere diese Datei zu ".env" und trage deine Werte ein:
#     cp .env.example .env
# ============================================================

# Flask
SECRET_KEY=bitte-hier-einen-zufaelligen-wert-eintragen
FLASK_DEBUG=0

# ------------------------------------------------------------
#  E-Mail-Versand (SMTP)
#  Damit Kontakt- & Buchungsanfragen wirklich in dein Postfach kommen.
#  Beispiel für viele Hoster / Gmail (App-Passwort nötig!):
# ------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine-adresse@gmail.com
SMTP_PASS=dein-app-passwort
SMTP_USE_TLS=1

# Absender- und Empfängeradresse der Benachrichtigungen
MAIL_FROM=deine-adresse@gmail.com
MAIL_TO=huerth@koerperformen.com

# Hinweis: Ohne SMTP-Daten funktioniert die Seite trotzdem –
# Anfragen werden dann lokal in data/leads.jsonl gespeichert
# und in der Konsole ausgegeben (praktisch zum Testen).
