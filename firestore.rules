rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Hilfsfunktionen ──
    function signedIn() {
      return request.auth != null;
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isChef() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myProfile().role == 'chef';
    }

    // ── Benutzerprofile ──
    match /users/{uid} {
      allow read: if signedIn();
      // eigenes Profil (Chef-Registrierung) ODER der Chef legt Mitarbeiter an
      allow create: if request.auth.uid == uid || isChef();
      // eigenes Profil ODER der Chef ordnet Studios zu
      allow update: if request.auth.uid == uid || isChef();
      // nur der Chef kann einen Zugang entfernen
      allow delete: if isChef();
    }

    // ── Chat-Nachrichten ──
    match /channels/{channelId}/messages/{msgId} {
      allow read: if signedIn();
      // Nur als man selbst senden; Bilder/Text begrenzen
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
      allow update: if false;
      // Chef darf jede Nachricht löschen; Mitarbeiter nur eigene innerhalb 1 Stunde
      allow delete: if isChef()
        || (signedIn()
            && resource.data.uid == request.auth.uid
            && request.time.toMillis() < resource.data.ts + 3600000);
    }

    // ── Aufgaben pro Studio ──
    match /studios/{studioKey}/todos/{todoId} {
      allow read: if signedIn();
      allow create: if isChef();                       // Aufgaben nur vom Chef
      allow delete: if isChef();
      // Mitarbeiter dürfen abhaken / Foto anhängen (update erlaubt für Eingeloggte)
      allow update: if signedIn();
    }

    // ── Ankündigungen ──
    match /announcements/{annId} {
      allow read: if signedIn();
      allow create: if isChef()
        && request.resource.data.uid == request.auth.uid;
      // Chef darf alles; Mitarbeiter dürfen nur das Lesen markieren (readBy)
      allow update: if isChef()
        || (signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']));
      allow delete: if isChef();
    }

    // ── Materialbestand pro Studio ──
    // Jeder Eingeloggte darf den Bestand lesen und eintragen.
    match /inventory/{studioKey} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // ── Dokumente (Metadaten) ──
    match /documents/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isChef();
    }
    // ── Dokument-Inhalte (kleine Dateien direkt in der Datenbank, kostenlos) ──
    match /documentData/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isChef();
    }

    // ── Konfiguration (z. B. Onboarding-Checkliste) ──
    match /config/{doc} {
      allow read: if signedIn();
      allow write: if isChef();
    }

    // ── Direktnachrichten (1:1) – nur die beiden Beteiligten ──
    // dmId hat die Form  dm_<uidA>_<uidB>
    match /dms/{dmId} {
      // Lesen/Abfragen über das participants-Feld (funktioniert auch für Listen-Abfragen)
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;
    }
    match /dms/{dmId}/messages/{msgId} {
      allow read: if signedIn() && dmId.split('_').hasAny([request.auth.uid]);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && dmId.split('_').hasAny([request.auth.uid]);
      // Update nur für Beteiligte (z. B. Checklisten-Häkchen)
      allow update: if signedIn() && dmId.split('_').hasAny([request.auth.uid]);
      allow delete: if signedIn() && dmId.split('_').hasAny([request.auth.uid])
        && (isChef()
            || (resource.data.uid == request.auth.uid
                && request.time.toMillis() < resource.data.ts + 3600000));
    }

    // ── Marketing-App (marketing.html): Kampagnen-Projekte mit Versionen ──
    // Jeder Eingeloggte darf lesen und Projekte anlegen/pflegen.
    // Löschen: nur Chef oder wer das Projekt bzw. die Version angelegt hat.
    match /mkProjects/{projectId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if signedIn();
      allow delete: if isChef()
        || (signedIn() && resource.data.createdBy == request.auth.uid);

      match /versions/{versionId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.createdBy == request.auth.uid;
        // Versionen sind unveränderlich (Historie bleibt echt)
        allow update: if false;
        allow delete: if isChef()
          || (signedIn() && resource.data.createdBy == request.auth.uid);
      }
    }

    // ── Push-Tokens (für Benachrichtigungen) ──
    // Die Server-Funktion liest sie per Admin-Rechten; Clients schreiben nur ihren eigenen.
    match /pushTokens/{token} {
      allow read: if false;
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
