rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Hilfsfunktionen ──
    function signedIn() {
      return request.auth != null;
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isChef() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myProfile().role == 'chef';
    }

    // ── Benutzerprofile ──
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if request.auth.uid == uid;        // eigenes Profil bei Registrierung
      allow update: if request.auth.uid == uid;        // nur eigenes Profil ändern
      allow delete: if false;
    }

    // ── Chat-Nachrichten ──
    match /channels/{channelId}/messages/{msgId} {
      allow read: if signedIn();
      // Nur als man selbst senden; Bilder/Text begrenzen
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
      allow update: if false;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid; // eigene löschbar
    }

    // ── Aufgaben pro Studio ──
    match /studios/{studioKey}/todos/{todoId} {
      allow read: if signedIn();
      allow create: if isChef();                       // Aufgaben nur vom Chef
      allow delete: if isChef();
      // Mitarbeiter dürfen abhaken / Foto anhängen (update erlaubt für Eingeloggte)
      allow update: if signedIn();
    }

    // ── Ankündigungen ──
    match /announcements/{annId} {
      allow read: if signedIn();
      allow create: if isChef()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isChef();
    }

    // ── Materialbestand pro Studio ──
    // Jeder Eingeloggte darf den Bestand lesen und eintragen.
    match /inventory/{studioKey} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // ── Push-Tokens (für Benachrichtigungen) ──
    // Die Server-Funktion liest sie per Admin-Rechten; Clients schreiben nur ihren eigenen.
    match /pushTokens/{token} {
      allow read: if false;
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
